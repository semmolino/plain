<!doctype html>
<html lang="de">
<head>
<meta charset="utf-8">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: Arial, Helvetica, sans-serif;
  font-size: 10pt;
  color: #1a1a1a;
  line-height: 1.4;
}

/* ── Page breaks ─────────────────────────────────────── */
.page { page-break-after: always; }
.page:last-child { page-break-after: auto; }
.letter-header { page-break-inside: avoid; }
.calc-table { page-break-inside: avoid; }
.payment-note-row { page-break-inside: avoid; }

/* ── Page 1 layout ───────────────────────────────────── */

.logo-area {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 6mm;
  min-height: 4mm;
}
.logo-area img {
  max-height: {{ (theme.header.logoMaxHeightMm or 20) }}mm;
  max-width: 70mm;
  object-fit: contain;
}

.sender-line {
  font-size: 7.5pt;
  color: #6b7280;
  border-bottom: 0.3pt solid #d1d5db;
  padding-bottom: 1mm;
  margin-bottom: 5mm;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* DIN 676 letter layout: address window left, meta right */
.letter-header {
  display: flex;
  gap: 10mm;
  margin-bottom: 8mm;
  align-items: flex-start;
}
.address-col {
  width: 85mm;
  flex-shrink: 0;
}
.address-block {
  font-size: 10pt;
  line-height: 1.5;
  min-height: 35mm;
}
.address-block .name1 { font-weight: 600; }

.meta-col { flex: 1; }

.meta-table { width: 100%; border-collapse: collapse; font-size: 9pt; }
.meta-table td { padding: 0.8mm 0; vertical-align: top; }
.meta-table td.ml { color: #6b7280; width: 32mm; padding-right: 2mm; }
.meta-table td.mv { font-weight: 500; }
.meta-table td.mv.bold { font-weight: 700; }
.meta-sep { border-top: 0.3pt solid #d1d5db; padding-top: 1.5mm; height: 3mm; }

/* Reference / project line */
.ref-block {
  margin-bottom: 6mm;
  font-size: 9pt;
  color: #374151;
  display: flex;
  flex-wrap: wrap;
  gap: 0 8mm;
}
.ref-block .rf { display: flex; gap: 2mm; }
.ref-block .rl { color: #6b7280; }

/* Document title */
.doc-title {
  font-size: 14pt;
  font-weight: 700;
  margin-bottom: 5mm;
  color: #111827;
}

/* Free text blocks */
.text-block {
  font-size: 10pt;
  margin-bottom: 5mm;
  white-space: pre-line;
  line-height: 1.5;
}

/* Briefanrede über dem Kopftext */
.salutation {
  font-size: 10pt;
  margin-bottom: 3mm;
  line-height: 1.5;
}

/* ── Calculation table ───────────────────────────────── */
.calc-table {
  width: 100%;
  border-collapse: collapse;
  margin: 4mm 0 6mm 0;
}
.calc-table td {
  padding: 1.5mm 0;
  font-size: 10pt;
  vertical-align: baseline;
}
.calc-table td.label { color: #374151; }
.calc-table td.amount {
  text-align: right;
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
  padding-left: 6mm;
}
.calc-table tr.sep td { padding: 0; height: 2mm; }
.calc-table tr.sep td.line-cell {
  border-top: 0.5pt solid #9ca3af;
}
.calc-table tr.total-row td {
  font-weight: 700;
  font-size: 11pt;
  padding-top: 2mm;
  border-top: 1pt solid #1a1a1a;
}
.calc-table tr.due-row td {
  font-weight: 700;
  padding-top: 2mm;
  border-top: 0.5pt solid #9ca3af;
}

/* Payment note */
.payment-note-row {
  display: flex;
  align-items: flex-start;
  gap: 6mm;
  margin-top: 5mm;
}
.payment-note-text { flex: 1; }
.payment-qr {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.payment-qr img {
  width: 28mm;
  height: 28mm;
  display: block;
}
.payment-qr-caption {
  font-size: 7pt;
  color: #6b7280;
  margin-top: 1mm;
  text-align: center;
}
.payment-note {
  font-size: 9.5pt;
  color: #374151;
  line-height: 1.5;
}
.payment-note strong { color: #1a1a1a; }

/* ── Appendix pages ──────────────────────────────────── */
.appendix-header {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 4mm;
}
.appendix-header img {
  max-height: 12mm;
  max-width: 50mm;
  object-fit: contain;
}

.appendix-title {
  font-size: 11pt;
  font-weight: 700;
  margin-bottom: 4mm;
  color: #111827;
  border-bottom: 0.5pt solid #d1d5db;
  padding-bottom: 1.5mm;
}
.appendix-subtitle {
  font-size: 9pt;
  color: #6b7280;
  margin-bottom: 3mm;
}

/* Generic appendix table */
.data-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 9pt;
}
.data-table th {
  text-align: left;
  font-weight: 600;
  color: #374151;
  border-bottom: 0.5pt solid #9ca3af;
  padding: 1.5mm 2mm 1.5mm 0;
}
.data-table th.r, .data-table td.r {
  text-align: right;
  padding-left: 3mm;
}
.data-table td {
  padding: 1.5mm 2mm 1.5mm 0;
  border-bottom: 0.3pt solid #e5e7eb;
  vertical-align: top;
}
.data-table tr.sum-row td {
  font-weight: 700;
  border-top: 0.5pt solid #9ca3af;
  border-bottom: none;
  padding-top: 2mm;
}
/* Gruppierung nach Projektelement im Leistungsnachweis */
.data-table tr.group-row { break-after: avoid; }
.data-table tr.group-row td {
  font-weight: 700;
  color: #111827;
  background: #f3f4f6;
  border-top: 0.8pt solid #9ca3af;
  border-bottom: 0.4pt solid #cbd5e1;
  padding: 2.2mm 2mm;
}
.data-table tbody tr.group-row:first-child td { border-top: none; }
.data-table tr.subtotal-row td {
  font-weight: 600;
  color: #374151;
  border-top: 0.5pt solid #9ca3af;
  border-bottom: none;
  padding-top: 1.5mm;
  padding-bottom: 2.5mm;
}
.data-table .muted { color: #6b7280; font-size: 8.5pt; }
.data-table .bold  { font-weight: 600; }

/* Footer is rendered by Playwright footerTemplate from __footerCols data */
body { padding-bottom: 4mm; }

/* ── HOAI appendix – shared with honorar.njk ────────────── */
.basis-grid { display: grid; grid-template-columns: repeat(3,1fr); gap:3mm; margin-bottom:2mm; page-break-inside: avoid; }
.basis-cell { padding:2mm 3mm; background:#f9fafb; border:0.3pt solid #e5e7eb; border-radius:2pt; }
.basis-cell .bc-label { font-size:7.5pt; color:#6b7280; margin-bottom:0.5mm; }
.basis-cell .bc-val   { font-size:9.5pt; font-weight:600; }
.section-title-h { font-size:9pt; font-weight:700; color:#374151; text-transform:uppercase;
  letter-spacing:0.03em; margin:6mm 0 2mm; padding-bottom:1mm; border-bottom:0.5pt solid #d1d5db;
  page-break-after: avoid; }
.surcharge-detail { font-size:7.5pt; color:#6b7280; margin-top:0.5mm; }
.breakdown-row td { background:#fafafa; border-bottom:0.3pt solid #e5e7eb; padding:1mm 2mm 1.5mm 8mm; }
.breakdown-table { width:100%; border-collapse:collapse; font-size:7.5pt; }
.breakdown-table th { font-size:6.5pt; color:#9ca3af; font-weight:600; padding:0 1mm 0.5mm; text-align:right; }
.breakdown-table th:first-child { text-align:left; }
.breakdown-table td { padding:0.4mm 1mm; }
.breakdown-table td.bd-num { text-align:right; white-space:nowrap; width:22%; }
.breakdown-table tr.bd-lph td, .breakdown-table tr.bd-bl td { color:#374151; }
.surcharge-mode-badge { display:inline-block; font-size:6.5pt; padding:0 2mm; border-radius:2pt;
  background:#e0f2fe; color:#0369a1; font-weight:600; margin-left:1mm; vertical-align:middle; }
.honorar-summary { margin-top:8mm; padding:4mm 5mm; background:#f0f9ff;
  border:0.5pt solid #bae6fd; border-radius:3pt; page-break-inside: avoid; }
.honorar-summary table { width:100%; border-collapse:collapse; }
.honorar-summary td { padding:1.2mm 0; font-size:9.5pt; }
.honorar-summary td.sl { color:#374151; }
.honorar-summary td.sv { text-align:right; font-weight:600; white-space:nowrap; }
.honorar-summary tr.gesamthonorar td { font-size:12pt; font-weight:700;
  border-top:1pt solid #0284c7; padding-top:2mm; }
table.data-table tfoot td { border-top:1pt solid #374151; border-bottom:none;
  font-weight:600; padding-top:2mm; }
table.data-table tfoot tr.grand-total td { font-size:11pt; font-weight:700;
  color:#111827; padding-top:2mm; }
table.data-table td.num { text-align:right; white-space:nowrap; }
table.data-table th.num { text-align:right; }
table.data-table { page-break-inside: auto; }
table.data-table tbody tr { page-break-inside: avoid; }
table.data-table thead { display: table-header-group; }
</style>
{% include "modern_a/_theme_head.njk" %}
</head>
<body>

{# ──────────────────────────────────────────────────────── #}
{# PAGE 1 – Main invoice                                   #}
{# ──────────────────────────────────────────────────────── #}
<div class="page">

  {# Logo #}
  <div class="logo-area">
    {% if theme.header.showLogo and logoDataUri %}
      <img src="{{ logoDataUri }}" alt="Logo">
    {% endif %}
  </div>

  {# Sender line (tiny, above address window) #}
  <div class="sender-line">
    {{ inv.seller.name }}{% if inv.seller.street %} &middot; {{ inv.seller.street }}{% endif %}{% if inv.seller.postCode or inv.seller.city %} &middot; {{ inv.seller.postCode }} {{ inv.seller.city }}{% endif %}
  </div>

  {# Two-column: buyer address | meta block #}
  <div class="letter-header">

    <div class="address-col">
      <div class="address-block">
        <div class="name1">{{ inv.buyer.name }}</div>
        {% if buyerName2 %}<div>{{ buyerName2 }}</div>{% endif %}
        {% if inv.buyer.street %}<div>{{ inv.buyer.street }}</div>{% endif %}
        <div>{{ inv.buyer.postCode }} {{ inv.buyer.city }}</div>
      </div>
    </div>

    <div class="meta-col">
      <table class="meta-table">
        {% if inv.seller.contactName %}
        <tr>
          <td class="ml">Kontakt</td>
          <td class="mv">{{ inv.seller.contactName }}</td>
        </tr>
        {% endif %}
        {% if inv.seller.contactPhone %}
        <tr>
          <td class="ml">Telefon</td>
          <td class="mv">{{ inv.seller.contactPhone }}</td>
        </tr>
        {% endif %}
        {% if inv.seller.contactEmail %}
        <tr>
          <td class="ml">E-Mail</td>
          <td class="mv">{{ inv.seller.contactEmail }}</td>
        </tr>
        {% endif %}
        <tr><td class="meta-sep" colspan="2"></td></tr>
        <tr>
          <td class="ml">Datum</td>
          <td class="mv">{{ inv.date | date_de }}</td>
        </tr>
        <tr>
          <td class="ml">{% if inv.invoiceType == 'partial_payment' %}Abschlags-Nr.{% else %}Rechnungs-Nr.{% endif %}</td>
          <td class="mv bold">{{ inv.number }}</td>
        </tr>
        {% if inv.dueDate %}
        <tr>
          <td class="ml">Zahlungsziel</td>
          <td class="mv">{{ inv.dueDate | date_de }}</td>
        </tr>
        {% endif %}
      </table>
    </div>
  </div>

  {# Reference / project info bar #}
  <div class="ref-block">
    {% if inv.buyerReference %}
    <div class="rf"><span class="rl">Ihre Zeichen:</span><span>{{ inv.buyerReference }}</span></div>
    {% endif %}
    {% if projectName %}
    <div class="rf"><span class="rl">Projekt:</span><span>{{ projectName }}</span></div>
    {% endif %}
    {% if contractName %}
    <div class="rf"><span class="rl">Auftrag:</span><span>{{ contractName }}</span></div>
    {% endif %}
    {% if inv.billingPeriodStart or inv.billingPeriodEnd %}
    <div class="rf"><span class="rl">Leistungszeitraum:</span><span>{{ inv.billingPeriodStart | date_range_de(inv.billingPeriodEnd) }}</span></div>
    {% endif %}
  </div>

  {# Document title #}
  <div class="doc-title">{{ docTitle }}</div>

  {# Anrede — geschlechtsgerechte Briefanrede direkt über dem Kopftext #}
  {% if salutationLine %}<div class="salutation">{{ salutationLine }}</div>{% endif %}

  {# Optional intro text #}
  {% if text1 %}<div class="text-block">{{ text1 }}</div>{% endif %}

  {# ── Calculation table ── #}
  <table class="calc-table">

    {% if inv.invoiceType == 'schlussrechnung' or inv.invoiceType == 'teilschlussrechnung' %}

    {# Schlussrechnung: Honorar → Nebenkosten → Zwischensumme → abzgl. AR → MwSt → Rechnungssumme #}
    <tr>
      <td class="label">erbrachtes Honorar</td>
      <td class="amount">{{ amountNet | money }}</td>
    </tr>
    {% if amountExtrasNet and amountExtrasNet != 0 %}
    <tr>
      <td class="label">zzgl. Nebenkosten</td>
      <td class="amount">{{ amountExtrasNet | money }}</td>
    </tr>
    <tr class="sep"><td class="line-cell"></td><td class="line-cell"></td></tr>
    <tr>
      <td class="label">Zwischensumme</td>
      <td class="amount">{{ inv.totals.lineTotal | money }}</td>
    </tr>
    {% endif %}

    {% if deductionTotals.net > 0 %}
    <tr class="sep"><td class="line-cell"></td><td class="line-cell"></td></tr>
    <tr>
      <td class="label">abzgl. Abschlagsrechnungen</td>
      <td class="amount">&minus;&#8239;{{ deductionTotals.net | money }}</td>
    </tr>
    <tr class="sep"><td class="line-cell"></td><td class="line-cell"></td></tr>
    <tr>
      <td class="label">Rechnungssumme netto</td>
      <td class="amount">{{ (inv.totals.lineTotal - deductionTotals.net) | money }}</td>
    </tr>
    {% endif %}

    {% if discounts.hasDiscounts %}
    <tr class="sep"><td class="line-cell"></td><td class="line-cell"></td></tr>
    {% if discounts.d1Percent > 0 %}
    <tr>
      <td class="label">abzgl. {{ discounts.d1Reason if discounts.d1Reason else "Nachlass I" }} ({{ discounts.d1Percent }}&#8239;%)</td>
      <td class="amount">&minus;&#8239;{{ discounts.d1Amount | money }}</td>
    </tr>
    {% endif %}
    {% if discounts.d2Percent > 0 %}
    <tr>
      <td class="label">abzgl. {{ discounts.d2Reason if discounts.d2Reason else "Nachlass II" }} ({{ discounts.d2Percent }}&#8239;%)</td>
      <td class="amount">&minus;&#8239;{{ discounts.d2Amount | money }}</td>
    </tr>
    {% endif %}
    <tr class="sep"><td class="line-cell"></td><td class="line-cell"></td></tr>
    <tr>
      <td class="label">Rechnungssumme netto</td>
      <td class="amount">{{ discounts.adjustedNet | money }}</td>
    </tr>
    <tr class="sep"><td class="line-cell"></td><td class="line-cell"></td></tr>
    <tr>
      <td class="label">zzgl. {{ inv.vatBreakdown[0].rate }}&#8239;% Mehrwertsteuer</td>
      <td class="amount">{{ discounts.adjustedVat | money }}</td>
    </tr>
    <tr class="total-row">
      <td class="label">Rechnungssumme brutto</td>
      <td class="amount">{{ discounts.adjustedGross | money }}</td>
    </tr>
    {% if securityRetention and securityRetention.hasSe %}
    <tr>
      <td class="label">./. Sicherheitseinbehalt {{ securityRetention.pct | round(2) }}&#8239;% vom {% if securityRetention.basis == 'NETTO' %}Netto{% else %}Brutto{% endif %}</td>
      <td class="amount">− {{ securityRetention.amount | money }}</td>
    </tr>
    {% endif %}
    {% if securityRetention and securityRetention.hasSeRelease %}
    {% for r in securityRetention.releaseRows %}
    <tr>
      <td class="label" style="color:#15803d">+ Auflösung Sicherheitseinbehalt aus Nr. {{ r.number }} v. {{ r.date | date_de }}</td>
      <td class="amount" style="color:#15803d">+ {{ r.amount | money }}</td>
    </tr>
    {% endfor %}
    {% endif %}
    {% if securityRetention and (securityRetention.hasSe or securityRetention.hasSeRelease) %}
    <tr class="total-row">
      <td class="label">Zahlungsbetrag</td>
      <td class="amount">{{ securityRetention.payable | money }}</td>
    </tr>
    {% endif %}
    {% else %}
    <tr class="sep"><td class="line-cell"></td><td class="line-cell"></td></tr>
    {% for vat in inv.vatBreakdown %}
    <tr>
      <td class="label">zzgl. {{ vat.rate }}&#8239;% Mehrwertsteuer</td>
      <td class="amount">{{ vat.amount | money }}</td>
    </tr>
    {% endfor %}

    <tr class="total-row">
      <td class="label">Rechnungssumme brutto</td>
      <td class="amount">{{ inv.totals.grandTotal | money }}</td>
    </tr>
    {% if securityRetention and securityRetention.hasSe %}
    <tr>
      <td class="label">./. Sicherheitseinbehalt {{ securityRetention.pct | round(2) }}&#8239;% vom {% if securityRetention.basis == 'NETTO' %}Netto{% else %}Brutto{% endif %}</td>
      <td class="amount">− {{ securityRetention.amount | money }}</td>
    </tr>
    {% endif %}
    {% if securityRetention and securityRetention.hasSeRelease %}
    {% for r in securityRetention.releaseRows %}
    <tr>
      <td class="label" style="color:#15803d">+ Auflösung Sicherheitseinbehalt aus Nr. {{ r.number }} v. {{ r.date | date_de }}</td>
      <td class="amount" style="color:#15803d">+ {{ r.amount | money }}</td>
    </tr>
    {% endfor %}
    {% endif %}
    {% if securityRetention and (securityRetention.hasSe or securityRetention.hasSeRelease) %}
    <tr class="total-row">
      <td class="label">Zahlungsbetrag</td>
      <td class="amount">{{ securityRetention.payable | money }}</td>
    </tr>
    {% endif %}
    {% endif %}

    {% else %}

    {# Regular invoice / Abschlagsrechnung layout #}
    {% if arProgress and arProgress.hasPrior %}
    {# Kumulative Abschlagsrechnung-Header (#9) #}
    <tr>
      <td class="label">Erbrachtes Honorar</td>
      <td class="amount">{{ arProgress.cumulativeNet | money }}</td>
    </tr>
    <tr>
      <td class="label">abzgl. bisheriger Abschlagsrechnungen</td>
      <td class="amount">&minus;&#8239;{{ arProgress.priorNet | money }}</td>
    </tr>
    <tr class="sep"><td class="line-cell"></td><td class="line-cell"></td></tr>
    <tr>
      <td class="label">In dieser Rechnung</td>
      <td class="amount">{{ arProgress.thisNet | money }}</td>
    </tr>
    {% else %}
    <tr>
      <td class="label">erbrachtes Honorar</td>
      <td class="amount">{{ amountNet | money }}</td>
    </tr>
    {% endif %}
    {% if amountExtrasNet and amountExtrasNet != 0 %}
    <tr>
      <td class="label">zzgl. Nebenkosten</td>
      <td class="amount">{{ amountExtrasNet | money }}</td>
    </tr>
    {% endif %}

    {% if discounts.hasDiscounts %}
    <tr class="sep"><td class="line-cell"></td><td class="line-cell"></td></tr>
    {% if discounts.d1Percent > 0 %}
    <tr>
      <td class="label">abzgl. {{ discounts.d1Reason if discounts.d1Reason else "Nachlass I" }} ({{ discounts.d1Percent }}&#8239;%)</td>
      <td class="amount">&minus;&#8239;{{ discounts.d1Amount | money }}</td>
    </tr>
    {% endif %}
    {% if discounts.d2Percent > 0 %}
    <tr>
      <td class="label">abzgl. {{ discounts.d2Reason if discounts.d2Reason else "Nachlass II" }} ({{ discounts.d2Percent }}&#8239;%)</td>
      <td class="amount">&minus;&#8239;{{ discounts.d2Amount | money }}</td>
    </tr>
    {% endif %}
    <tr class="sep"><td class="line-cell"></td><td class="line-cell"></td></tr>
    <tr>
      <td class="label">Rechnungssumme netto</td>
      <td class="amount">{{ discounts.adjustedNet | money }}</td>
    </tr>
    <tr class="sep"><td class="line-cell"></td><td class="line-cell"></td></tr>
    <tr>
      <td class="label">zzgl. {{ inv.vatBreakdown[0].rate }}&#8239;% Mehrwertsteuer</td>
      <td class="amount">{{ discounts.adjustedVat | money }}</td>
    </tr>
    <tr class="total-row">
      <td class="label">Rechnungssumme</td>
      <td class="amount">{{ discounts.adjustedGross | money }}</td>
    </tr>
    {% if securityRetention and securityRetention.hasSe %}
    <tr>
      <td class="label">./. Sicherheitseinbehalt {{ securityRetention.pct | round(2) }}&#8239;% vom {% if securityRetention.basis == 'NETTO' %}Netto{% else %}Brutto{% endif %}</td>
      <td class="amount">− {{ securityRetention.amount | money }}</td>
    </tr>
    {% endif %}
    {% if securityRetention and securityRetention.hasSeRelease %}
    {% for r in securityRetention.releaseRows %}
    <tr>
      <td class="label" style="color:#15803d">+ Auflösung Sicherheitseinbehalt aus Nr. {{ r.number }} v. {{ r.date | date_de }}</td>
      <td class="amount" style="color:#15803d">+ {{ r.amount | money }}</td>
    </tr>
    {% endfor %}
    {% endif %}
    {% if securityRetention and (securityRetention.hasSe or securityRetention.hasSeRelease) %}
    <tr class="total-row">
      <td class="label">Zahlungsbetrag</td>
      <td class="amount">{{ securityRetention.payable | money }}</td>
    </tr>
    {% endif %}
    {% else %}
    <tr class="sep"><td class="line-cell"></td><td class="line-cell"></td></tr>
    {% for vat in inv.vatBreakdown %}
    <tr>
      <td class="label">zzgl. {{ vat.rate }}&#8239;% Mehrwertsteuer</td>
      <td class="amount">{{ vat.amount | money }}</td>
    </tr>
    {% endfor %}
    <tr class="total-row">
      <td class="label">Rechnungssumme</td>
      <td class="amount">{{ inv.totals.grandTotal | money }}</td>
    </tr>
    {% if securityRetention and securityRetention.hasSe %}
    <tr>
      <td class="label">./. Sicherheitseinbehalt {{ securityRetention.pct | round(2) }}&#8239;% vom {% if securityRetention.basis == 'NETTO' %}Netto{% else %}Brutto{% endif %}</td>
      <td class="amount">− {{ securityRetention.amount | money }}</td>
    </tr>
    {% endif %}
    {% if securityRetention and securityRetention.hasSeRelease %}
    {% for r in securityRetention.releaseRows %}
    <tr>
      <td class="label" style="color:#15803d">+ Auflösung Sicherheitseinbehalt aus Nr. {{ r.number }} v. {{ r.date | date_de }}</td>
      <td class="amount" style="color:#15803d">+ {{ r.amount | money }}</td>
    </tr>
    {% endfor %}
    {% endif %}
    {% if securityRetention and (securityRetention.hasSe or securityRetention.hasSeRelease) %}
    <tr class="total-row">
      <td class="label">Zahlungsbetrag</td>
      <td class="amount">{{ securityRetention.payable | money }}</td>
    </tr>
    {% endif %}
    {% endif %}

    {% endif %}

    {% if securityRetention and securityRetention.hasSe %}
    <p style="margin-top:6mm;font-size:9pt;color:#374151;line-height:1.4">
      Hinweis: Der Sicherheitseinbehalt in Höhe von <strong>{{ securityRetention.amount | money }}</strong>
      ({{ securityRetention.pct | round(2) }}&#8239;% vom {% if securityRetention.basis == 'NETTO' %}Netto{% else %}Brutto{% endif %}){% if securityRetention.legalReference %} gem. {{ securityRetention.legalReference }}{% endif %}
      wird einbehalten und mit der Schluss-/Teilschlussrechnung aufgelöst.
    </p>
    {% endif %}

  </table>

  {# Payment instruction / closing text #}
  {% if text2 %}
  <div class="text-block">{{ text2 }}</div>
  {% else %}
  <div class="payment-note-row">
    <div class="payment-note-text">
      <div class="payment-note">
        Bitte überweisen Sie
        {% if payAmount %}<strong>{{ payAmount | money }}</strong>{% elif discounts.hasDiscounts %}<strong>{{ discounts.adjustedGross | money }}</strong>{% else %}<strong>{{ inv.totals.grandTotal | money }}</strong>{% endif %}
        unter Angabe der Rechnungsnummer <strong>{{ inv.number }}</strong>
        {% if inv.dueDate %}bis zum <strong>{{ inv.dueDate | date_de }}</strong>{% endif %}
        auf folgendes Konto:{% if inv.seller.iban %}<br>
        IBAN: <strong>{{ inv.seller.iban }}</strong>{% if inv.seller.bic %} &nbsp;&middot;&nbsp; BIC: <strong>{{ inv.seller.bic }}</strong>{% endif %}{% endif %}
      </div>
      {% if discounts.hasSkonto %}
      <div class="payment-note" style="margin-top:6px;">
        Bei Zahlung innerhalb von <strong>{{ discounts.cashDiscountDays }}&#8239;Tagen</strong> gewähren wir <strong>{{ discounts.cashDiscountPercent }}&#8239;% Skonto</strong> — Sie können in diesem Fall <strong>{{ discounts.skontoPaymentAmount | money }}</strong> überweisen.
      </div>
      {% endif %}
    </div>
    {% if epcQrDataUri %}
    <div class="payment-qr">
      <img src="{{ epcQrDataUri }}" alt="GiroCode">
      <div class="payment-qr-caption">GiroCode</div>
    </div>
    {% endif %}
  </div>
  {% endif %}

</div>{# end page 1 #}


{# ──────────────────────────────────────────────────────── #}
{# PAGE 2 – Zahlungsübersicht (all doc types, if project   #}
{#          has any partial payments)                       #}
{# ──────────────────────────────────────────────────────── #}
{% if projectPayments and projectPayments.length > 0 %}
<div class="page">

  <div class="appendix-header">
    {% if theme.header.showLogo and logoDataUri %}
      <img src="{{ logoDataUri }}" alt="Logo">
    {% endif %}
  </div>

  <div class="appendix-title">Zahlungsübersicht</div>
  <div class="appendix-subtitle">Projekt: {{ projectName }} &middot; Stand: {{ inv.date | date_de }}</div>

  <table class="data-table">
    <thead>
      <tr>
        <th>Abschlags-Nr.</th>
        <th>Datum</th>
        <th class="r">Netto</th>
        <th class="r">MwSt.</th>
        <th class="r">Brutto</th>
      </tr>
    </thead>
    <tbody>
      {% for p in projectPayments %}
      <tr{% if p.isCurrent %} style="font-weight:600;"{% endif %}>
        <td>{{ p.number }}{% if p.isCurrent %} &#x25C6;{% endif %}</td>
        <td style="white-space:nowrap;">{{ p.date | date_de }}</td>
        <td class="r">{{ p.netAmount   | money }}</td>
        <td class="r">{{ p.vatAmount   | money }}</td>
        <td class="r">{{ p.grossAmount | money }}</td>
      </tr>
      {% endfor %}
      <tr class="sum-row">
        <td colspan="2">Summe</td>
        <td class="r">{{ paymentTotals.net   | money }}</td>
        <td class="r">{{ paymentTotals.vat   | money }}</td>
        <td class="r">{{ paymentTotals.gross | money }}</td>
      </tr>
    </tbody>
  </table>

</div>
{% endif %}


{# ──────────────────────────────────────────────────────── #}
{# PAGE 3 – Leistungsstandsübersicht                       #}
{# ──────────────────────────────────────────────────────── #}
{% if projectStructureRows and projectStructureRows.length > 0 %}
<div class="page">

  <div class="appendix-header">
    {% if theme.header.showLogo and logoDataUri %}
      <img src="{{ logoDataUri }}" alt="Logo">
    {% endif %}
  </div>

  <div class="appendix-title">Leistungsstandsübersicht / Honorarberechnung</div>
  <div class="appendix-subtitle">{{ projectName }}{% if contractName %} &middot; {{ contractName }}{% endif %} &middot; Stand: {{ inv.date | date_de }}</div>

  <table class="data-table">
    <thead>
      <tr>
        <th>Leistungsphase</th>
        <th class="r">Auftragswert</th>
        <th class="r">Abgerechnet bis dato</th>
        <th class="r">Diese Rechnung</th>
        <th class="r">% erbracht</th>
      </tr>
    </thead>
    <tbody>
      {% for r in projectStructureRows %}
      <tr{% if not r.isLeaf %} style="background:rgba(17,24,39,0.04); font-weight:600;"{% endif %}>
        <td style="padding-left:{{ (r.depth or 0) * 4 + 2 }}mm">
          <div{% if not r.isLeaf %} class="bold"{% else %} class="bold" style="font-weight:500"{% endif %}>{{ r.nameShort }}</div>
          {% if r.nameLong %}<div class="muted">{{ r.nameLong }}</div>{% endif %}
        </td>
        <td class="r">{{ r.feeTotal      | money }}</td>
        <td class="r">{{ r.alreadyBilled | money }}</td>
        <td class="r">{{ r.thisDocNet    | money }}</td>
        <td class="r">{{ r.performedPct }}&#8239;%</td>
      </tr>
      {% endfor %}
      <tr class="sum-row">
        <td>Summe</td>
        <td class="r">{{ structureTotals.feeTotal      | money }}</td>
        <td class="r">{{ structureTotals.alreadyBilled | money }}</td>
        <td class="r">{{ structureTotals.thisDocNet    | money }}</td>
        <td></td>
      </tr>
    </tbody>
  </table>

  {% if structureSurchargesTotal > 0 %}
  <div style="margin-top:8mm; font-size:9pt; font-weight:700; color:#374151; border-bottom:0.5pt solid #d1d5db; padding-bottom:1mm;">Zuschlagsübersicht</div>
  <table class="data-table" style="margin-top:3mm">
    <thead>
      <tr>
        <th>Leistungsphase</th>
        <th class="r">Honorar (Basis)</th>
        <th>Zuschlag</th>
        <th class="r">%</th>
        <th class="r">Betrag</th>
      </tr>
    </thead>
    <tbody>
      {% for r in surchargeSummaryRows %}
        {% if r.s1Label %}
        <tr>
          <td><span class="bold">{{ r.nameShort }}</span>{% if r.nameLong %} – {{ r.nameLong }}{% endif %}</td>
          <td class="r">{{ r.revenueBasis | money }}</td>
          <td>{{ r.s1Label }}</td>
          <td class="r">{{ r.s1Pct | round(2) }}&#8239;%</td>
          <td class="r">{{ r.s1Eur | money }}</td>
        </tr>
        {% endif %}
        {% if r.s2Label %}
        <tr>
          <td></td><td></td>
          <td>{{ r.s2Label }}</td>
          <td class="r">{{ r.s2Pct | round(2) }}&#8239;%</td>
          <td class="r">{{ r.s2Eur | money }}</td>
        </tr>
        {% endif %}
        {% if r.s3Label %}
        <tr>
          <td></td><td></td>
          <td>{{ r.s3Label }}</td>
          <td class="r">{{ r.s3Pct | round(2) }}&#8239;%</td>
          <td class="r">{{ r.s3Eur | money }}</td>
        </tr>
        {% endif %}
      {% endfor %}
      <tr class="sum-row">
        <td colspan="4">Gesamt Zuschläge</td>
        <td class="r">{{ structureSurchargesTotal | money }}</td>
      </tr>
    </tbody>
  </table>
  {% endif %}

</div>
{% endif %}


{# ──────────────────────────────────────────────────────── #}
{# PAGE 4 – Nachweisleistungen (TEC entries)               #}
{# ──────────────────────────────────────────────────────── #}
{% if tec.rows and tec.rows.length > 0 %}
<div class="page">

  <div class="appendix-header">
    {% if theme.header.showLogo and logoDataUri %}
      <img src="{{ logoDataUri }}" alt="Logo">
    {% endif %}
  </div>

  <div class="appendix-title">Nachweisleistungen</div>
  <div class="appendix-subtitle">{{ docTitle }} {{ inv.number }} &middot; Leistungsnachweis</div>

  <table class="data-table">
    <thead>
      <tr>
        <th>Datum</th>
        <th>Mitarbeiter</th>
        <th class="r">Menge</th>
        <th class="r">Stundensatz</th>
        <th class="r">Summe</th>
        <th>Buchungstext</th>
      </tr>
    </thead>
    <tbody>
      {% for g in tec.groups %}
      <tr class="group-row">
        <td colspan="6">{% if g.kuerzel or g.bezeichnung %}{{ g.kuerzel }}{% if g.kuerzel and g.bezeichnung %} &ndash; {% endif %}{{ g.bezeichnung }}{% else %}Ohne Projektelement{% endif %}</td>
      </tr>
      {% for t in g.rows %}
      <tr>
        <td style="white-space:nowrap;">{{ t.dateVoucher | date_de }}</td>
        <td>{{ t.employeeName }}</td>
        <td class="r">{{ t.quantityExt }}</td>
        <td class="r">{{ t.spRate | money }}</td>
        <td class="r">{{ t.spTot  | money }}</td>
        <td>{{ t.postingDescription }}</td>
      </tr>
      {% endfor %}
      <tr class="subtotal-row">
        <td colspan="2">Zwischensumme</td>
        <td class="r">{{ g.sumQty }}</td>
        <td></td>
        <td class="r">{{ g.sumTot | money }}</td>
        <td></td>
      </tr>
      {% endfor %}
      <tr class="sum-row">
        <td colspan="2">Gesamtsumme</td>
        <td class="r">{{ tec.sumQty }}</td>
        <td></td>
        <td class="r">{{ tec.sumTot | money }}</td>
        <td></td>
      </tr>
    </tbody>
  </table>

</div>
{% endif %}

{# ──────────────────────────────────────────────────────────────────────── #}
{# HOAI-Honorarübersicht (one page per Kalkulation – matches standalone honorar.njk) #}
{# ─────────────────────────────────────────────────────────────────────────────────── #}
{% if honorarCalcs and honorarCalcs.length > 0 %}
{% for hc in honorarCalcs %}
<div class="page">

  <div class="appendix-header">
    {% if theme.header.showLogo and logoDataUri %}
      <img src="{{ logoDataUri }}" alt="Logo">
    {% endif %}
  </div>

  <div class="appendix-title" style="font-size:14pt;">HOAI-Honorarübersicht</div>
  <div class="appendix-subtitle">
    {{ hc.nameShort }}{% if hc.nameLong %} – {{ hc.nameLong }}{% endif %}
    &middot; {{ projectName }} &middot; Stand: {{ inv.date | date_de }}
  </div>

  {# Basisdaten #}
  <div class="section-title-h">Basisdaten</div>
  <div class="basis-grid">
    <div class="basis-cell"><div class="bc-label">Honorarordnung</div><div class="bc-val">{{ hc.calc.nameShort }}</div></div>
    <div class="basis-cell"><div class="bc-label">Honorarzone</div><div class="bc-val">{{ hc.calc.zoneName or "—" }}</div></div>
    <div class="basis-cell"><div class="bc-label">Zonenanteil</div><div class="bc-val">{{ hc.calc.zonePercent or "—" }} %</div></div>
  </div>

  {% set hasKx = hc.calc.constructionCostsK0 or hc.calc.constructionCostsK1 or hc.calc.constructionCostsK2 or hc.calc.constructionCostsK3 or hc.calc.constructionCostsK4 %}
  {% if hasKx %}
  <table class="data-table" style="margin-top:3mm">
    <thead><tr><th style="width:12%">Kx</th><th class="num">Baukosten €</th><th class="num">Grundhonorar €</th></tr></thead>
    <tbody>
      {% for k in ['K0','K1','K2','K3','K4'] %}
      {% if hc.calc['constructionCosts' + k] %}
      <tr>
        <td>{{ k }}</td>
        <td class="num">{{ hc.calc['constructionCosts' + k] | money }}</td>
        <td class="num">{{ hc.calc['revenue' + k] | money }}</td>
      </tr>
      {% endif %}
      {% endfor %}
    </tbody>
  </table>
  {% endif %}

  {# Leistungsphasen #}
  {% if hc.phases and hc.phases.length %}
  <div class="section-title-h">Leistungsphasen</div>
  <table class="data-table">
    <thead>
      <tr>
        <th style="width:38%">Leistungsphase</th>
        <th>Kx</th>
        <th class="num">Basis €</th>
        <th class="num">Basis %</th>
        <th class="num">Basis-Honorar €</th>
        <th class="num">Honorar %</th>
        <th class="num">Honorar €</th>
      </tr>
    </thead>
    <tbody>
      {% for p in hc.phases %}
      <tr>
        <td>{{ p.phaseLabel }}</td>
        <td>{{ p.kx }}</td>
        <td class="num">{{ p.revenueBase | money }}</td>
        <td class="num">{{ p.feePercentBase }}</td>
        <td class="num">{{ p.basisHonorar | money }}</td>
        <td class="num">{{ p.feePercent }}</td>
        <td class="num">{{ p.phaseRevenue | money }}</td>
      </tr>
      {% endfor %}
    </tbody>
    <tfoot>
      <tr><td colspan="5">Grundhonorar</td><td></td><td class="num">{{ hc.grundhonorar | money }}</td></tr>
    </tfoot>
  </table>
  {% endif %}

  {# Besondere Leistungen #}
  {% if hc.blItems and hc.blItems.length %}
  <div class="section-title-h">Besondere Leistungen</div>
  <table class="data-table">
    <thead>
      <tr>
        <th style="width:12%">Kürzel</th>
        <th style="width:45%">Bezeichnung</th>
        <th>LPH-Bezug</th>
        <th class="num">Betrag €</th>
      </tr>
    </thead>
    <tbody>
      {% for b in hc.blItems %}
      <tr>
        <td>{{ b.nameShort or "—" }}</td>
        <td>{{ b.name }}</td>
        <td>{{ b.lphLabel or b.lphRef or "—" }}</td>
        <td class="num">{{ b.amount | money }}</td>
      </tr>
      {% endfor %}
    </tbody>
    <tfoot><tr><td colspan="3">Summe Besondere Leistungen</td><td class="num">{{ hc.blTotal | money }}</td></tr></tfoot>
  </table>
  {% endif %}

  {# Zuschläge / Nachlässe #}
  {% if hc.surcharges and hc.surcharges.length %}
  <div class="section-title-h">Zuschläge &amp; Nachlässe</div>
  <table class="data-table">
    <thead>
      <tr>
        <th style="width:45%">Bezeichnung</th>
        <th class="num">%</th>
        <th class="num">Basis €</th>
        <th class="num">Betrag €</th>
      </tr>
    </thead>
    <tbody>
      {% for s in hc.surcharges %}
      <tr>
        <td>
          {{ s.nameLong or s.nameShort or "—" }}
          {% if s.calcMode == 'cumulative' %}<span class="surcharge-mode-badge">Kumulativ</span>{% endif %}
          {% if s.lphDetail %}<div class="surcharge-detail">Basis: {{ s.lphDetail }}</div>{% endif %}
        </td>
        <td class="num">{{ s.percent }}</td>
        <td class="num">{{ s.baseAmount | money }}</td>
        <td class="num">{{ s.amount | money }}</td>
      </tr>
      {% set hasDetail = (s.lphItems and s.lphItems.length > 0) or (s.surchargeBls and s.surchargeBls.length > 0) %}
      {% if hasDetail %}
      <tr class="breakdown-row">
        <td colspan="4">
          <table class="breakdown-table">
            <thead><tr>
              <th>Komponente</th>
              <th style="text-align:right">Basis €</th>
              <th style="text-align:right">Zuschlag €</th>
            </tr></thead>
            <tbody>
              {% for item in s.lphItems %}
              <tr class="bd-lph"><td>{{ item.label }}</td><td class="bd-num">{{ item.baseAmount | money }}</td><td class="bd-num">{{ item.surchargeAmount | money }}</td></tr>
              {% endfor %}
              {% for item in s.surchargeBls %}
              <tr class="bd-bl"><td>{{ item.name }}</td><td class="bd-num">{{ item.baseAmount | money }}</td><td class="bd-num">{{ item.surchargeAmount | money }}</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </td>
      </tr>
      {% endif %}
      {% endfor %}
    </tbody>
    <tfoot>
      <tr>
        <td colspan="3">Summe Zuschläge / Nachlässe</td>
        <td class="num">{{ hc.zuschlaegeSum | money }}</td>
      </tr>
    </tfoot>
  </table>
  {% endif %}

  {# Zusammenfassung #}
  <div class="honorar-summary">
    <table>
      <tr><td class="sl">Grundhonorar (Summe Leistungsphasen)</td><td class="sv">{{ hc.grundhonorar | money }}</td></tr>
      {% if hc.blItems and hc.blItems.length %}<tr><td class="sl">Besondere Leistungen</td><td class="sv">{{ hc.blTotal | money }}</td></tr>{% endif %}
      {% if hc.surcharges and hc.surcharges.length %}<tr><td class="sl">Zuschläge / Nachlässe</td><td class="sv">{{ hc.zuschlaegeSum | money }}</td></tr>{% endif %}
      <tr class="gesamthonorar"><td class="sl">Gesamthonorar (netto)</td><td class="sv">{{ hc.gesamthonorar | money }}</td></tr>
    </table>
  </div>

</div>
{% endfor %}
{% endif %}


</body>
</html>