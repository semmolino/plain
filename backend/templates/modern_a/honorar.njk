<!doctype html>
<html lang="de">
<head>
<meta charset="utf-8">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: Arial, Helvetica, sans-serif;
  font-size: 10pt;
  color: #1a1a1a;
  line-height: 1.4;
}

.logo-area {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 6mm;
  min-height: 4mm;
}
.logo-area img { max-height: 20mm; max-width: 70mm; object-fit: contain; }

.sender-line {
  font-size: 7.5pt;
  color: #6b7280;
  border-bottom: 0.3pt solid #d1d5db;
  padding-bottom: 1mm;
  margin-bottom: 8mm;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.doc-title {
  font-size: 14pt;
  font-weight: 700;
  margin-bottom: 1mm;
}
.doc-meta {
  font-size: 9pt;
  color: #6b7280;
  margin-bottom: 8mm;
}

.section-title {
  font-size: 9pt;
  font-weight: 700;
  color: #374151;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  margin-bottom: 2mm;
  margin-top: 6mm;
  padding-bottom: 1mm;
  border-bottom: 0.5pt solid #d1d5db;
}

table.data-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 9pt;
}
table.data-table th {
  text-align: left;
  padding: 2mm 2mm;
  background: #f3f4f6;
  border-bottom: 0.8pt solid #d1d5db;
  font-weight: 600;
  white-space: nowrap;
}
table.data-table td {
  padding: 1.5mm 2mm;
  border-bottom: 0.3pt solid #e5e7eb;
  vertical-align: top;
}
table.data-table .num { text-align: right; white-space: nowrap; }
table.data-table tfoot td {
  border-top: 1pt solid #374151;
  border-bottom: none;
  font-weight: 600;
  padding-top: 2mm;
}
table.data-table { page-break-inside: auto; }
table.data-table tbody tr { page-break-inside: avoid; }
table.data-table tfoot tr.grand-total td {
  font-size: 11pt;
  font-weight: 700;
  color: #111827;
  padding-top: 2mm;
}

.basis-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 3mm;
  margin-bottom: 2mm;
}
.basis-cell { padding: 2mm 3mm; background: #f9fafb; border: 0.3pt solid #e5e7eb; border-radius: 2pt; }
.basis-cell .bc-label { font-size: 7.5pt; color: #6b7280; margin-bottom: 0.5mm; }
.basis-cell .bc-val   { font-size: 9.5pt; font-weight: 600; }

.surcharge-detail {
  font-size: 7.5pt;
  color: #6b7280;
  margin-top: 0.5mm;
}
.breakdown-row td {
  background: #fafafa;
  border-bottom: 0.3pt solid #e5e7eb;
  padding: 1mm 2mm 1.5mm 8mm;
}
.breakdown-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 7.5pt;
}
.breakdown-table th { font-size: 6.5pt; color: #9ca3af; font-weight: 600; padding: 0 1mm 0.5mm; text-align: right; }
.breakdown-table th:first-child { text-align: left; }
.breakdown-table td { padding: 0.4mm 1mm; }
.breakdown-table td.bd-num { text-align: right; white-space: nowrap; width: 22%; }
.breakdown-table tr.bd-lph td { color: #374151; }
.breakdown-table tr.bd-bl td  { color: #374151; }
.surcharge-mode-badge {
  display: inline-block;
  font-size: 6.5pt;
  padding: 0 2mm;
  border-radius: 2pt;
  background: #e0f2fe;
  color: #0369a1;
  font-weight: 600;
  margin-left: 1mm;
  vertical-align: middle;
}

.summary-block {
  margin-top: 8mm;
  padding: 4mm 5mm;
  background: #f0f9ff;
  border: 0.5pt solid #bae6fd;
  border-radius: 3pt;
}
.summary-block table { width: 100%; border-collapse: collapse; }
.summary-block td { padding: 1.2mm 0; font-size: 9.5pt; }
.summary-block td.sl { color: #374151; }
.summary-block td.sv { text-align: right; font-weight: 600; white-space: nowrap; }
.summary-block tr.gesamthonorar td { font-size: 12pt; font-weight: 700; border-top: 1pt solid #0284c7; padding-top: 2mm; }

.doc-footer {
  margin-top: 10mm;
  display: flex;
  gap: 5mm;
  padding-top: 3mm;
  border-top: 0.3pt solid #d1d5db;
  font-size: 7pt;
  color: #6b7280;
  line-height: 1.55;
}
.doc-footer-col { flex: 1; }
.doc-footer-col strong { color: #374151; font-weight: 600; display: block; margin-bottom: 0.5mm; font-size: 7.5pt; }
</style>
</head>
<body>

{# Logo #}
<div class="logo-area">
  {% if logoDataUri %}
    <img src="{{ logoDataUri }}" alt="Logo">
  {% endif %}
</div>

{# Sender line #}
<div class="sender-line">
  {{ seller.name }}{% if seller.street %} &middot; {{ seller.street }}{% endif %}{% if seller.postCode or seller.city %} &middot; {{ seller.postCode }} {{ seller.city }}{% endif %}
</div>

{# Document title #}
<div class="doc-title">Honorarberechnung</div>
<div class="doc-meta">
  {{ calc.nameLong or calc.nameShort or "HOAI-Kalkulation" }}
  {% if projectLabel %} &middot; Projekt: {{ projectLabel }}{% endif %}
  &middot; Stand: {{ docDate | date_de }}
</div>

{# Basisdaten #}
<div class="section-title">Basisdaten</div>
<div class="basis-grid">
  <div class="basis-cell">
    <div class="bc-label">Honorarordnung</div>
    <div class="bc-val">{{ calc.nameShort }}</div>
  </div>
  <div class="basis-cell">
    <div class="bc-label">Honorarzone</div>
    <div class="bc-val">{{ calc.zoneName or "—" }}</div>
  </div>
  <div class="basis-cell">
    <div class="bc-label">Zonenanteil</div>
    <div class="bc-val">{{ calc.zonePercent or "—" }} %</div>
  </div>
</div>

{% set hasKx = calc.constructionCostsK0 or calc.constructionCostsK1 or calc.constructionCostsK2 or calc.constructionCostsK3 or calc.constructionCostsK4 %}
{% if hasKx %}
<table class="data-table" style="margin-top:3mm">
  <thead>
    <tr>
      <th style="width:12%">Kx</th>
      <th class="num">Baukosten €</th>
      <th class="num">Grundhonorar €</th>
    </tr>
  </thead>
  <tbody>
    {% for k in ['K0','K1','K2','K3','K4'] %}
    {% if calc['constructionCosts' + k] %}
    <tr>
      <td>{{ k }}</td>
      <td class="num">{{ calc['constructionCosts' + k] | money }}</td>
      <td class="num">{{ calc['revenue' + k] | money }}</td>
    </tr>
    {% endif %}
    {% endfor %}
  </tbody>
</table>
{% endif %}

{# Leistungsphasen #}
{% if phases and phases.length %}
<div class="section-title">Leistungsphasen</div>
<table class="data-table">
  <thead>
    <tr>
      <th style="width:38%">Leistungsphase</th>
      <th>Kx</th>
      <th class="num">Basis €</th>
      <th class="num">Basis %</th>
      <th class="num">Basis-Honorar €</th>
      <th class="num">Honorar %</th>
      <th class="num">Honorar €</th>
    </tr>
  </thead>
  <tbody>
    {% for p in phases %}
    <tr>
      <td>{{ p.phaseLabel }}</td>
      <td>{{ p.kx }}</td>
      <td class="num">{{ p.revenueBase | money }}</td>
      <td class="num">{{ p.feePercentBase }}</td>
      <td class="num">{{ p.basisHonorar | money }}</td>
      <td class="num">{{ p.feePercent }}</td>
      <td class="num">{{ p.phaseRevenue | money }}</td>
    </tr>
    {% endfor %}
  </tbody>
  <tfoot>
    <tr>
      <td colspan="5">Grundhonorar</td>
      <td></td>
      <td class="num">{{ grundhonorar | money }}</td>
    </tr>
  </tfoot>
</table>
{% endif %}

{# Besondere Leistungen — appears before surcharges, same order as wizard #}
{% if blItems and blItems.length %}
<div class="section-title">Besondere Leistungen</div>
<table class="data-table">
  <thead>
    <tr>
      <th style="width:12%">Kürzel</th>
      <th style="width:45%">Bezeichnung</th>
      <th>LPH-Bezug</th>
      <th class="num">Betrag €</th>
    </tr>
  </thead>
  <tbody>
    {% for b in blItems %}
    <tr>
      <td>{{ b.nameShort or "—" }}</td>
      <td>{{ b.name }}</td>
      <td>{{ b.lphLabel or b.lphRef or "—" }}</td>
      <td class="num">{{ b.amount | money }}</td>
    </tr>
    {% endfor %}
  </tbody>
  <tfoot>
    <tr>
      <td colspan="3">Summe Besondere Leistungen</td>
      <td class="num">{{ blTotal | money }}</td>
    </tr>
  </tfoot>
</table>
{% endif %}

{# Zuschläge / Nachlässe #}
{% if surcharges and surcharges.length %}
<div class="section-title">Zuschläge &amp; Nachlässe</div>
<table class="data-table">
  <thead>
    <tr>
      <th style="width:45%">Bezeichnung</th>
      <th class="num">%</th>
      <th class="num">Basis €</th>
      <th class="num">Betrag €</th>
    </tr>
  </thead>
  <tbody>
    {% for s in surcharges %}
    <tr>
      <td>
        {{ s.nameLong or s.nameShort or "—" }}
        {% if s.calcMode == 'cumulative' %}<span class="surcharge-mode-badge">Kumulativ</span>{% endif %}
        {% if s.lphDetail %}
        <div class="surcharge-detail">Basis: {{ s.lphDetail }}</div>
        {% endif %}
      </td>
      <td class="num">{{ s.percent }}</td>
      <td class="num">{{ s.baseAmount | money }}</td>
      <td class="num">{{ s.amount | money }}</td>
    </tr>
    {% set hasDetail = (s.lphItems and s.lphItems.length > 0) or (s.surchargeBls and s.surchargeBls.length > 0) %}
    {% if hasDetail %}
    <tr class="breakdown-row">
      <td colspan="4">
        <table class="breakdown-table">
          <thead>
            <tr>
              <th>Komponente</th>
              <th style="text-align:right">Basis €</th>
              <th style="text-align:right">Zuschlag €</th>
            </tr>
          </thead>
          <tbody>
            {% for item in s.lphItems %}
            <tr class="bd-lph">
              <td>{{ item.label }}</td>
              <td class="bd-num">{{ item.baseAmount | money }}</td>
              <td class="bd-num">{{ item.surchargeAmount | money }}</td>
            </tr>
            {% endfor %}
            {% for item in s.surchargeBls %}
            <tr class="bd-bl">
              <td>{{ item.name }}</td>
              <td class="bd-num">{{ item.baseAmount | money }}</td>
              <td class="bd-num">{{ item.surchargeAmount | money }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </td>
    </tr>
    {% endif %}
    {% endfor %}
  </tbody>
</table>
{% endif %}

{# Summary #}
<div class="summary-block">
  <table>
    <tr>
      <td class="sl">Grundhonorar (Summe Leistungsphasen)</td>
      <td class="sv">{{ grundhonorar | money }}</td>
    </tr>
    {% if blItems and blItems.length %}
    <tr>
      <td class="sl">Besondere Leistungen</td>
      <td class="sv">{{ blTotal | money }}</td>
    </tr>
    {% endif %}
    {% if surcharges and surcharges.length %}
    <tr>
      <td class="sl">Zuschläge / Nachlässe</td>
      <td class="sv">{{ zuschlaegeSum | money }}</td>
    </tr>
    {% endif %}
    <tr class="gesamthonorar">
      <td class="sl">Gesamthonorar (netto)</td>
      <td class="sv">{{ gesamthonorar | money }}</td>
    </tr>
  </table>
</div>

{# Fixed footer #}
<div class="doc-footer">
  {% if seller.name %}
  <div class="doc-footer-col">
    <strong>{{ seller.name }}</strong>
    {% if seller.street %}<span>{{ seller.street }}</span><br>{% endif %}
    {% if seller.postCode or seller.city %}<span>{{ seller.postCode }} {{ seller.city }}</span>{% endif %}
  </div>
  {% endif %}
  {% if seller.iban or seller.bic %}
  <div class="doc-footer-col">
    <strong>Bankverbindung</strong>
    {% if seller.iban %}<span>IBAN: {{ seller.iban }}</span><br>{% endif %}
    {% if seller.bic %}<span>BIC: {{ seller.bic }}</span>{% endif %}
  </div>
  {% endif %}
  {% if seller.taxId or seller.taxNumber %}
  <div class="doc-footer-col">
    <strong>Steuer</strong>
    {% if seller.taxId %}<span>USt-IdNr.: {{ seller.taxId }}</span><br>{% endif %}
    {% if seller.taxNumber %}<span>Steuernr.: {{ seller.taxNumber }}</span>{% endif %}
  </div>
  {% endif %}
</div>

</body>
</html>
