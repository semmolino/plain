<!doctype html>
<html lang="de">
<head>
<meta charset="utf-8">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: Arial, Helvetica, sans-serif;
  font-size: 10pt;
  color: #1a1a1a;
  line-height: 1.4;
}

.logo-area {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 6mm;
  min-height: 4mm;
}
.logo-area img {
  max-height: {{ (theme.header.logoMaxHeightMm or 20) }}mm;
  max-width: 70mm;
  object-fit: contain;
}

.sender-line {
  font-size: 7.5pt;
  color: #6b7280;
  border-bottom: 0.3pt solid #d1d5db;
  padding-bottom: 1mm;
  margin-bottom: 5mm;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.letter-header {
  display: flex;
  gap: 10mm;
  margin-bottom: 8mm;
  align-items: flex-start;
}
.address-col { width: 85mm; flex-shrink: 0; }
.address-block { font-size: 10pt; line-height: 1.5; min-height: 35mm; }
.address-block .name1 { font-weight: 600; }

.meta-col { flex: 1; }
.meta-table { width: 100%; border-collapse: collapse; font-size: 9pt; }
.meta-table td { padding: 0.8mm 0; vertical-align: top; }
.meta-table td.ml { color: #6b7280; width: 36mm; padding-right: 2mm; }
.meta-table td.mv { font-weight: 500; }
.meta-table td.mv.bold { font-weight: 700; }
.meta-sep { border-top: 0.3pt solid #d1d5db; padding-top: 1.5mm; height: 3mm; }

.doc-title {
  font-size: 14pt;
  font-weight: 700;
  margin-bottom: 5mm;
  color: #111827;
}

.text-block {
  font-size: 10pt;
  margin-bottom: 5mm;
  white-space: pre-line;
  line-height: 1.5;
}

/* ── Positions table ─────────────────────────────────────── */
.pos-table {
  width: 100%;
  border-collapse: collapse;
  margin: 4mm 0 6mm 0;
  font-size: 9.5pt;
}
.pos-table th {
  text-align: left;
  font-weight: 600;
  color: #374151;
  border-bottom: 0.5pt solid #9ca3af;
  padding: 1.5mm 2mm 1.5mm 0;
}
.pos-table th.r { text-align: right; padding-left: 3mm; }
.pos-table td {
  padding: 1.5mm 2mm 1.5mm 0;
  border-bottom: 0.3pt solid #e5e7eb;
  vertical-align: top;
}
.pos-table td.r {
  text-align: right;
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
  padding-left: 3mm;
}
.pos-table tr.parent-row td { font-weight: 600; background: #f9fafb; }
.pos-table tr.leaf-row td { }
.pos-table .sub-info { font-size: 8.5pt; color: #6b7280; }

/* ── Calculation table ───────────────────────────────────── */
.calc-table {
  width: 100%;
  border-collapse: collapse;
  margin: 4mm 0 6mm 0;
}
.calc-table td { padding: 1.5mm 0; font-size: 10pt; vertical-align: baseline; }
.calc-table td.label { color: #374151; }
.calc-table td.amount {
  text-align: right;
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
  padding-left: 6mm;
}
.calc-table tr.sep td { padding: 0; height: 2mm; }
.calc-table tr.sep td.line-cell { border-top: 0.5pt solid #9ca3af; }
.calc-table tr.total-row td {
  font-weight: 700;
  font-size: 11pt;
  padding-top: 2mm;
  border-top: 1pt solid #1a1a1a;
}

/* ── Bestellblatt ────────────────────────────────────────── */
.page-break { page-break-before: always; }

.bestellblatt-title {
  font-size: 14pt;
  font-weight: 700;
  margin-bottom: 2mm;
  color: #111827;
}
.bestellblatt-subtitle {
  font-size: 10pt;
  color: #6b7280;
  margin-bottom: 8mm;
}

.info-box {
  border: 0.5pt solid #d1d5db;
  border-radius: 2mm;
  padding: 4mm 5mm;
  margin-bottom: 7mm;
  background: #f9fafb;
}
.info-box table { width: 100%; border-collapse: collapse; font-size: 9.5pt; }
.info-box td { padding: 1mm 0; vertical-align: top; }
.info-box td.lbl { color: #6b7280; width: 50mm; }
.info-box td.val { font-weight: 500; }
.info-box td.val.total { font-weight: 700; font-size: 11pt; }

.acceptance-text {
  font-size: 10pt;
  line-height: 1.6;
  margin-bottom: 6mm;
  color: #1a1a1a;
}

.order-subject {
  font-size: 9.5pt;
  margin-bottom: 10mm;
  padding: 3mm 4mm;
  border-left: 2pt solid #374151;
  background: #f9fafb;
  color: #374151;
  font-style: italic;
}

.signature-section {
  margin-top: 18mm;
  display: flex;
  gap: 20mm;
}
.signature-field { flex: 1; }
.signature-line {
  border-top: 0.5pt solid #1a1a1a;
  padding-top: 2mm;
  font-size: 8.5pt;
  color: #6b7280;
  margin-top: 12mm;
}

.buyer-block {
  font-size: 9.5pt;
  line-height: 1.6;
  margin-bottom: 6mm;
  color: #374151;
}
</style>
</head>
<body>

{# ═══════════════════════════════════════ PAGE 1 – ANGEBOT ════════════════════════════════ #}
<div class="page">

  {# Logo #}
  <div class="logo-area">
    {% if theme.header.showLogo and logoDataUri %}
      <img src="{{ logoDataUri }}" alt="Logo">
    {% endif %}
  </div>

  {# Sender line #}
  <div class="sender-line">
    {{ seller.name }}{% if seller.street %} &middot; {{ seller.street }}{% endif %}{% if seller.postCode or seller.city %} &middot; {{ seller.postCode }} {{ seller.city }}{% endif %}
  </div>

  {# Two-column: buyer address | meta block #}
  <div class="letter-header">

    <div class="address-col">
      <div class="address-block">
        <div class="name1">{{ buyer.name }}</div>
        {% if buyer.name2 %}<div>{{ buyer.name2 }}</div>{% endif %}
        {% if buyer.street %}<div>{{ buyer.street }}</div>{% endif %}
        <div>{{ buyer.postCode }} {{ buyer.city }}</div>
      </div>
    </div>

    <div class="meta-col">
      <table class="meta-table">
        {% if employee %}
        <tr>
          <td class="ml">Ansprechpartner</td>
          <td class="mv">{{ employee.FIRST_NAME }} {{ employee.LAST_NAME }}</td>
        </tr>
        {% endif %}
        {% if contact and contact.EMAIL %}
        <tr>
          <td class="ml">E-Mail</td>
          <td class="mv">{{ contact.EMAIL }}</td>
        </tr>
        {% endif %}
        <tr><td class="meta-sep" colspan="2"></td></tr>
        <tr>
          <td class="ml">Datum</td>
          <td class="mv">{{ (offer.OFFER_DATE or offer.CREATED_AT) | date_de }}</td>
        </tr>
        {% if offer.VALID_UNTIL %}
        <tr>
          <td class="ml">Gültig bis</td>
          <td class="mv">{{ offer.VALID_UNTIL | date_de }}</td>
        </tr>
        {% endif %}
        <tr>
          <td class="ml">Angebots-Nr.</td>
          <td class="mv bold">{{ offer.NAME_SHORT }}</td>
        </tr>
      </table>
    </div>
  </div>

  {# Document title #}
  <div class="doc-title">Angebot: {{ offer.NAME_LONG }}</div>

  {# Kopftext #}
  {% if text1 %}<div class="text-block">{{ text1 }}</div>{% endif %}

  {# ── Positions table ── #}
  {% if structureRows and structureRows.length > 0 %}
  <table class="pos-table">
    <thead>
      <tr>
        <th style="width:18mm">Position</th>
        <th>Bezeichnung</th>
        <th class="r" style="width:26mm">Honorar</th>
        {% if hasExtras %}<th class="r" style="width:18mm">Nebenkosten</th>{% endif %}
        <th class="r" style="width:22mm">Gesamt</th>
      </tr>
    </thead>
    <tbody>
      {% for row in structureRows %}
      <tr class="{{ 'parent-row' if row.depth === 0 and not row.isLeaf else 'leaf-row' }}">
        <td style="padding-left: {{ row.depth * 5 + 2 }}mm">{{ row.nameShort }}</td>
        <td>
          {{ row.nameLong }}
          {% if row.isHourly and row.quantity > 0 %}
          <div class="sub-info">{{ row.quantity }}&thinsp;h &times; {{ row.spRate | money }}/h{% if row.roleName %} ({{ row.roleName }}){% endif %}</div>
          {% endif %}
        </td>
        <td class="r">{{ row.revenue | money }}</td>
        {% if hasExtras %}
        <td class="r">
          {% if row.extras > 0 %}{{ row.extras | money }}{% else %}&mdash;{% endif %}
        </td>
        {% endif %}
        <td class="r">{{ row.total | money }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}

  {# ── Calculation table ── #}
  <table class="calc-table">
    <tr>
      <td class="label">Honorar (netto)</td>
      <td class="amount">{{ totals.revenue | money }}</td>
    </tr>
    {% if hasExtras %}
    <tr>
      <td class="label">zzgl. Nebenkosten</td>
      <td class="amount">{{ totals.extras | money }}</td>
    </tr>
    {% endif %}
    <tr class="sep"><td class="line-cell"></td><td class="line-cell"></td></tr>
    <tr class="total-row">
      <td class="label">Angebotssumme (netto)</td>
      <td class="amount">{{ totals.total | money }}</td>
    </tr>
  </table>

  {# Fußtext #}
  {% if text2 %}<div class="text-block">{{ text2 }}</div>{% endif %}

</div>

{# ═══════════════════════════════════════ PAGE 2 – BESTELLBLATT ══════════════════════════ #}
<div class="page page-break">

  {# Logo #}
  <div class="logo-area">
    {% if theme.header.showLogo and logoDataUri %}
      <img src="{{ logoDataUri }}" alt="Logo">
    {% endif %}
  </div>

  <div class="bestellblatt-title">Bestellblatt</div>
  <div class="bestellblatt-subtitle">Bitte ausgefüllt und unterschrieben zurücksenden.</div>

  {# Reference info box #}
  <div class="info-box">
    <table>
      <tr>
        <td class="lbl">Angebots-Nr.</td>
        <td class="val">{{ offer.NAME_SHORT }}</td>
      </tr>
      <tr>
        <td class="lbl">Angebotsdatum</td>
        <td class="val">{{ (offer.OFFER_DATE or offer.CREATED_AT) | date_de }}</td>
      </tr>
      {% if offer.VALID_UNTIL %}
      <tr>
        <td class="lbl">Gültig bis</td>
        <td class="val">{{ offer.VALID_UNTIL | date_de }}</td>
      </tr>
      {% endif %}
      <tr>
        <td class="lbl">Auftragnehmer</td>
        <td class="val">{{ seller.name }}</td>
      </tr>
      <tr>
        <td class="lbl" style="padding-top:2mm;">Angebotssumme (netto)</td>
        <td class="val total" style="padding-top:2mm;">{{ totals.total | money }}</td>
      </tr>
    </table>
  </div>

  {# Acceptance statement #}
  <div class="acceptance-text">
    Hiermit erteilen wir den Auftrag gemäß Angebot Nr.&nbsp;<strong>{{ offer.NAME_SHORT }}</strong>
    vom&nbsp;{{ (offer.OFFER_DATE or offer.CREATED_AT) | date_de }}
    über&nbsp;<strong>{{ totals.total | money }}</strong>&nbsp;(netto)
    an&nbsp;{{ seller.name }}.
  </div>

  {# Order subject #}
  <div class="order-subject">{{ offer.NAME_LONG }}</div>

  {# Buyer info #}
  <div class="buyer-block">
    <strong>{{ buyer.name }}</strong>{% if buyer.name2 %}<br>{{ buyer.name2 }}{% endif %}
    {% if buyer.street %}<br>{{ buyer.street }}{% endif %}
    <br>{{ buyer.postCode }} {{ buyer.city }}
    {% if contact %}<br>{{ contact.FIRST_NAME }} {{ contact.LAST_NAME }}{% if contact.EMAIL %} &middot; {{ contact.EMAIL }}{% endif %}{% endif %}
  </div>

  {# Signature fields #}
  <div class="signature-section">
    <div class="signature-field">
      <div class="signature-line">Ort, Datum</div>
    </div>
    <div class="signature-field" style="flex: 2;">
      <div class="signature-line">Unterschrift, Firmenstempel (Auftraggeber)</div>
    </div>
  </div>

</div>

</body>
</html>
