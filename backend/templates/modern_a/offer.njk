<!doctype html>
<html lang="de">
<head>
<meta charset="utf-8">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: Arial, Helvetica, sans-serif;
  font-size: 10pt;
  color: #1a1a1a;
  line-height: 1.4;
}

.logo-area {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 6mm;
  min-height: 4mm;
}
.logo-area img {
  max-height: {{ (theme.header.logoMaxHeightMm or 20) }}mm;
  max-width: 70mm;
  object-fit: contain;
}

.sender-line {
  font-size: 7.5pt;
  color: #6b7280;
  border-bottom: 0.3pt solid #d1d5db;
  padding-bottom: 1mm;
  margin-bottom: 5mm;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.letter-header {
  display: flex;
  gap: 10mm;
  margin-bottom: 8mm;
  align-items: flex-start;
}
.address-col { width: 85mm; flex-shrink: 0; }
.address-block { font-size: 10pt; line-height: 1.5; min-height: 35mm; }
.address-block .name1 { font-weight: 600; }

.meta-col { flex: 1; }
.meta-table { width: 100%; border-collapse: collapse; font-size: 9pt; }
.meta-table td { padding: 0.8mm 0; vertical-align: top; }
.meta-table td.ml { color: #6b7280; width: 36mm; padding-right: 2mm; }
.meta-table td.mv { font-weight: 500; }
.meta-table td.mv.bold { font-weight: 700; }
.meta-sep { border-top: 0.3pt solid #d1d5db; padding-top: 1.5mm; height: 3mm; }

.doc-title {
  font-size: 14pt;
  font-weight: 700;
  margin-bottom: 5mm;
  color: #111827;
}

.text-block {
  font-size: 10pt;
  margin-bottom: 5mm;
  white-space: pre-line;
  line-height: 1.5;
}

/* ── Positions table ─────────────────────────────────────── */
.pos-table {
  width: 100%;
  border-collapse: collapse;
  margin: 4mm 0 6mm 0;
  font-size: 9.5pt;
}
.pos-table th {
  text-align: left;
  font-weight: 600;
  color: #374151;
  border-bottom: 0.5pt solid #9ca3af;
  padding: 1.5mm 2mm 1.5mm 0;
}
.pos-table th.r { text-align: right; padding-left: 3mm; }
.pos-table td {
  padding: 1.5mm 2mm 1.5mm 0;
  border-bottom: 0.3pt solid #e5e7eb;
  vertical-align: top;
}
.pos-table td.r {
  text-align: right;
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
  padding-left: 3mm;
}
.pos-table tr.parent-row td { font-weight: 600; background: #f9fafb; }
.pos-table tr.leaf-row td { }
.pos-table .sub-info { font-size: 8.5pt; color: #6b7280; }

/* ── Calculation table ───────────────────────────────────── */
.calc-table {
  width: 100%;
  border-collapse: collapse;
  margin: 4mm 0 6mm 0;
}
.calc-table td { padding: 1.5mm 0; font-size: 10pt; vertical-align: baseline; }
.calc-table td.label { color: #374151; }
.calc-table td.amount {
  text-align: right;
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
  padding-left: 6mm;
}
.calc-table tr.sep td { padding: 0; height: 2mm; }
.calc-table tr.sep td.line-cell { border-top: 0.5pt solid #9ca3af; }
.calc-table tr.total-row td {
  font-weight: 700;
  font-size: 11pt;
  padding-top: 2mm;
  border-top: 1pt solid #1a1a1a;
}

/* ── Signature image ─────────────────────────────────────── */
.signature-image {
  margin-top: 8mm;
}
.signature-image img {
  max-height: 22mm;
  max-width: 75mm;
  object-fit: contain;
  display: block;
}

/* ── Bestellblatt ────────────────────────────────────────── */
.page-break { page-break-before: always; }

.bestellblatt-title {
  font-size: 14pt;
  font-weight: 700;
  margin-bottom: 2mm;
  color: #111827;
}
.bestellblatt-subtitle {
  font-size: 10pt;
  color: #6b7280;
  margin-bottom: 8mm;
}

.info-box {
  border: 0.5pt solid #d1d5db;
  border-radius: 2mm;
  padding: 4mm 5mm;
  margin-bottom: 7mm;
  background: #f9fafb;
}
.info-box table { width: 100%; border-collapse: collapse; font-size: 9.5pt; }
.info-box td { padding: 1mm 0; vertical-align: top; }
.info-box td.lbl { color: #6b7280; width: 50mm; }
.info-box td.val { font-weight: 500; }
.info-box td.val.total { font-weight: 700; font-size: 11pt; }

.acceptance-text {
  font-size: 10pt;
  line-height: 1.6;
  margin-bottom: 6mm;
  color: #1a1a1a;
}

.order-subject {
  font-size: 9.5pt;
  margin-bottom: 10mm;
  padding: 3mm 4mm;
  border-left: 2pt solid #374151;
  background: #f9fafb;
  color: #374151;
  font-style: italic;
}

.signature-section {
  margin-top: 18mm;
  display: flex;
  gap: 20mm;
}
.signature-field { flex: 1; }
.signature-line {
  border-top: 0.5pt solid #1a1a1a;
  padding-top: 2mm;
  font-size: 8.5pt;
  color: #6b7280;
  margin-top: 12mm;
}

.buyer-block {
  font-size: 9.5pt;
  line-height: 1.6;
  margin-bottom: 6mm;
  color: #374151;
}

/* HOAI appendix pages */
.appendix-header {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 4mm;
  min-height: 4mm;
}
.appendix-header img { max-height: 14mm; max-width: 60mm; object-fit: contain; }
.appendix-title { font-size: 14pt; font-weight: 700; color: #111827; margin-bottom: 1mm; }
.appendix-subtitle { font-size: 9pt; color: #6b7280; margin-bottom: 4mm; }

.data-table { width: 100%; border-collapse: collapse; font-size: 9.5pt; margin-top: 3mm; }
.data-table th { text-align: left; padding: 1.5mm 2mm; border-bottom: 1pt solid #374151; font-size: 9pt; color: #374151; }
.data-table th.r, .data-table td.r { text-align: right; }
.data-table th.num, .data-table td.num { text-align: right; white-space: nowrap; }
.data-table td { padding: 1.5mm 2mm; border-bottom: 0.3pt solid #e5e7eb; vertical-align: top; }
.data-table .sum-row td { font-weight: 600; background: #f9fafb; border-top: 1pt solid #d1d5db; border-bottom: 0.5pt solid #d1d5db; }
.data-table tfoot td { font-size: 11pt; font-weight: 700; border-top: 1pt solid #374151; padding-top: 2mm; border-bottom: none; }
.data-table tfoot tr.grand-total td { font-size: 11pt; font-weight: 700; color: #111827; padding-top: 2mm; }

/* HOAI appendix – shared styles */
.basis-grid { display: grid; grid-template-columns: repeat(3,1fr); gap:3mm; margin-bottom:2mm; }
.basis-cell { padding:2mm 3mm; background:#f9fafb; border:0.3pt solid #e5e7eb; border-radius:2pt; }
.basis-cell .bc-label { font-size:7.5pt; color:#6b7280; margin-bottom:0.5mm; }
.basis-cell .bc-val   { font-size:9.5pt; font-weight:600; }
.section-title-h { font-size:9pt; font-weight:700; color:#374151; text-transform:uppercase;
  letter-spacing:0.03em; margin:6mm 0 2mm; padding-bottom:1mm; border-bottom:0.5pt solid #d1d5db; }
.surcharge-detail { font-size:7.5pt; color:#6b7280; margin-top:0.5mm; }
.breakdown-row td { background:#fafafa; border-bottom:0.3pt solid #e5e7eb; padding:1mm 2mm 1.5mm 8mm; }
.breakdown-table { width:100%; border-collapse:collapse; font-size:7.5pt; }
.breakdown-table th { font-size:6.5pt; color:#9ca3af; font-weight:600; padding:0 1mm 0.5mm; text-align:right; }
.breakdown-table th:first-child { text-align:left; }
.breakdown-table td { padding:0.4mm 1mm; }
.breakdown-table td.bd-num { text-align:right; white-space:nowrap; width:22%; }
.breakdown-table tr.bd-lph td, .breakdown-table tr.bd-bl td { color:#374151; }
.surcharge-mode-badge { display:inline-block; font-size:6.5pt; padding:0 2mm; border-radius:2pt;
  background:#e0f2fe; color:#0369a1; font-weight:600; margin-left:1mm; vertical-align:middle; }
.honorar-summary { margin-top:8mm; padding:4mm 5mm; background:#f0f9ff;
  border:0.5pt solid #bae6fd; border-radius:3pt; }
.honorar-summary table { width:100%; border-collapse:collapse; }
.honorar-summary td { padding:1.2mm 0; font-size:9.5pt; }
.honorar-summary td.sl { color:#374151; }
.honorar-summary td.sv { text-align:right; font-weight:600; white-space:nowrap; }
.honorar-summary tr.gesamthonorar td { font-size:12pt; font-weight:700;
  border-top:1pt solid #0284c7; padding-top:2mm; }
</style>
</head>
<body>

{# ═══════════════════════════════════════ PAGE 1 – ANGEBOT ════════════════════════════════ #}
<div class="page">

  {# Logo #}
  <div class="logo-area">
    {% if theme.header.showLogo and logoDataUri %}
      <img src="{{ logoDataUri }}" alt="Logo">
    {% endif %}
  </div>

  {# Sender line #}
  <div class="sender-line">
    {{ seller.name }}{% if seller.street %} &middot; {{ seller.street }}{% endif %}{% if seller.postCode or seller.city %} &middot; {{ seller.postCode }} {{ seller.city }}{% endif %}
  </div>

  {# Two-column: buyer address | meta block #}
  <div class="letter-header">

    <div class="address-col">
      <div class="address-block">
        <div class="name1">{{ buyer.name }}</div>
        {% if buyer.name2 %}<div>{{ buyer.name2 }}</div>{% endif %}
        {% if buyer.street %}<div>{{ buyer.street }}</div>{% endif %}
        <div>{{ buyer.postCode }} {{ buyer.city }}</div>
      </div>
    </div>

    <div class="meta-col">
      <table class="meta-table">
        {% if employee %}
        <tr>
          <td class="ml">Ansprechpartner</td>
          <td class="mv">{{ employee.FIRST_NAME }} {{ employee.LAST_NAME }}</td>
        </tr>
        {% endif %}
        {% if contact and contact.EMAIL %}
        <tr>
          <td class="ml">E-Mail</td>
          <td class="mv">{{ contact.EMAIL }}</td>
        </tr>
        {% endif %}
        <tr><td class="meta-sep" colspan="2"></td></tr>
        <tr>
          <td class="ml">Datum</td>
          <td class="mv">{{ (offer.OFFER_DATE or offer.CREATED_AT) | date_de }}</td>
        </tr>
        {% if offer.VALID_UNTIL %}
        <tr>
          <td class="ml">Gültig bis</td>
          <td class="mv">{{ offer.VALID_UNTIL | date_de }}</td>
        </tr>
        {% endif %}
        <tr>
          <td class="ml">Angebots-Nr.</td>
          <td class="mv bold">{{ offer.NAME_SHORT }}</td>
        </tr>
      </table>
    </div>
  </div>

  {# Document title #}
  <div class="doc-title">Angebot: {{ offer.NAME_LONG }}</div>

  {# Kopftext #}
  {% if text1 %}<div class="text-block">{{ text1 }}</div>{% endif %}

  {# ── Positions table ── #}
  {% if structureRows and structureRows.length > 0 %}
  <table class="pos-table">
    <thead>
      <tr>
        <th style="width:16mm">Position</th>
        <th>Bezeichnung</th>
        {% if hasSurcharges %}<th class="r" style="width:24mm">Honorar (Basis)</th>{% endif %}
        {% if hasSurcharges %}<th class="r" style="width:20mm">Zuschläge</th>{% endif %}
        <th class="r" style="width:{% if hasSurcharges %}20{% else %}26{% endif %}mm">Honorar</th>
        {% if hasExtras %}<th class="r" style="width:18mm">Nebenkosten</th>{% endif %}
        <th class="r" style="width:22mm">Gesamt</th>
      </tr>
    </thead>
    <tbody>
      {% for row in structureRows %}
      <tr class="{{ 'parent-row' if row.depth === 0 and not row.isLeaf else 'leaf-row' }}">
        <td style="padding-left: {{ row.depth * 5 + 2 }}mm">{{ row.nameShort }}</td>
        <td>
          {{ row.nameLong }}
          {% if row.isHourly and row.quantity > 0 %}
          <div class="sub-info">{{ row.quantity }}&thinsp;h &times; {{ row.spRate | money }}/h{% if row.roleName %} ({{ row.roleName }}){% endif %}</div>
          {% endif %}
        </td>
        {% if hasSurcharges %}
        <td class="r">{{ row.revenueBasis | money }}</td>
        <td class="r">{% if row.surchargesTotal > 0 %}{{ row.surchargesTotal | money }}{% else %}&mdash;{% endif %}</td>
        {% endif %}
        <td class="r">{{ row.revenue | money }}</td>
        {% if hasExtras %}
        <td class="r">
          {% if row.extras > 0 %}{{ row.extras | money }}{% else %}&mdash;{% endif %}
        </td>
        {% endif %}
        <td class="r">{{ row.total | money }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  {% if hasSurcharges %}
  <div style="margin-top:6mm; font-size:9pt; font-weight:700; color:#374151; border-bottom:0.5pt solid #d1d5db; padding-bottom:1mm;">Zuschlagsübersicht</div>
  <table class="pos-table" style="margin-top:3mm">
    <thead>
      <tr>
        <th style="width:18mm">Position</th>
        <th>Bezeichnung</th>
        <th>Zuschlag</th>
        <th class="r" style="width:14mm">%</th>
        <th class="r" style="width:26mm">Betrag</th>
      </tr>
    </thead>
    <tbody>
      {% for r in surchargeSummaryRows %}
        {% if r.s1Label %}
        <tr class="leaf-row">
          <td>{{ r.nameShort }}</td>
          <td>{% if r.nameLong %}{{ r.nameLong }}{% endif %}</td>
          <td>{{ r.s1Label }}</td>
          <td class="r">{{ r.s1Pct | round(2) }}&#8239;%</td>
          <td class="r">{{ r.s1Eur | money }}</td>
        </tr>
        {% endif %}
        {% if r.s2Label %}
        <tr class="leaf-row">
          <td></td><td></td>
          <td>{{ r.s2Label }}</td>
          <td class="r">{{ r.s2Pct | round(2) }}&#8239;%</td>
          <td class="r">{{ r.s2Eur | money }}</td>
        </tr>
        {% endif %}
        {% if r.s3Label %}
        <tr class="leaf-row">
          <td></td><td></td>
          <td>{{ r.s3Label }}</td>
          <td class="r">{{ r.s3Pct | round(2) }}&#8239;%</td>
          <td class="r">{{ r.s3Eur | money }}</td>
        </tr>
        {% endif %}
      {% endfor %}
    </tbody>
    <tfoot>
      <tr>
        <td colspan="4" style="font-weight:700">Gesamt Zuschläge</td>
        <td class="r" style="font-weight:700">{{ offerSurchargesTotal | money }}</td>
      </tr>
    </tfoot>
  </table>
  {% endif %}

  {% endif %}

  {# ── Calculation table ── #}
  {# Totals are from root-level OFFER_STRUCTURE nodes (includes parent surcharges).
     HOAI-Leistungen are shown in full detail on the appendix pages below. #}
  <table class="calc-table">
    {% if structureRows and structureRows.length > 0 %}
    <tr>
      <td class="label">Honorar (netto)</td>
      <td class="amount">{{ totals.revenue | money }}</td>
    </tr>
    {% if hasExtras %}
    <tr>
      <td class="label">zzgl. Nebenkosten</td>
      <td class="amount">{{ totals.extras | money }}</td>
    </tr>
    {% endif %}
    {% endif %}
    <tr class="sep"><td class="line-cell"></td><td class="line-cell"></td></tr>
    {% if vatPercent > 0 %}
    <tr>
      <td class="label">zzgl. {{ vatPercent }}&thinsp;% Mehrwertsteuer</td>
      <td class="amount">{{ vatAmount | money }}</td>
    </tr>
    {% endif %}
    <tr class="total-row">
      <td class="label">Angebotssumme {% if vatPercent > 0 %}(brutto){% else %}(netto){% endif %}</td>
      <td class="amount">{{ (grossTotal if vatPercent > 0 else totals.total) | money }}</td>
    </tr>
  </table>

  {# Fußtext #}
  {% if text2 %}<div class="text-block">{{ text2 }}</div>{% endif %}

  {# Signature image #}
  {% if signatureDataUri %}
  <div class="signature-image">
    <img src="{{ signatureDataUri }}" alt="Unterschrift">
  </div>
  {% endif %}

</div>

{# ═══════════════════════════════════════ HOAI-HONORARÜBERSICHT (matches honorar.njk) ═══ #}
{% if honorarCalcs and honorarCalcs.length > 0 %}
{% for hc in honorarCalcs %}
<div class="page page-break">

  <div class="appendix-header">
    {% if theme.header.showLogo and logoDataUri %}
      <img src="{{ logoDataUri }}" alt="Logo">
    {% endif %}
  </div>

  <div class="appendix-title">HOAI-Honorarübersicht</div>
  <div class="appendix-subtitle">
    {{ hc.nameShort }}{% if hc.nameLong %} – {{ hc.nameLong }}{% endif %}
    &middot; {{ offer.NAME_SHORT }}{% if offer.NAME_LONG %} – {{ offer.NAME_LONG }}{% endif %}
    &middot; Stand: {{ (offer.OFFER_DATE or offer.CREATED_AT) | date_de }}
  </div>

  {# Basisdaten #}
  <div class="section-title-h">Basisdaten</div>
  <div class="basis-grid">
    <div class="basis-cell"><div class="bc-label">Honorarordnung</div><div class="bc-val">{{ hc.calc.nameShort }}</div></div>
    <div class="basis-cell"><div class="bc-label">Honorarzone</div><div class="bc-val">{{ hc.calc.zoneName or "—" }}</div></div>
    <div class="basis-cell"><div class="bc-label">Zonenanteil</div><div class="bc-val">{{ hc.calc.zonePercent or "—" }} %</div></div>
  </div>

  {% set hasKx = hc.calc.constructionCostsK0 or hc.calc.constructionCostsK1 or hc.calc.constructionCostsK2 or hc.calc.constructionCostsK3 or hc.calc.constructionCostsK4 %}
  {% if hasKx %}
  <table class="data-table" style="margin-top:3mm">
    <thead><tr><th style="width:12%">Kx</th><th class="num">Baukosten €</th><th class="num">Grundhonorar €</th></tr></thead>
    <tbody>
      {% for k in ['K0','K1','K2','K3','K4'] %}
      {% if hc.calc['constructionCosts' + k] %}
      <tr>
        <td>{{ k }}</td>
        <td class="num">{{ hc.calc['constructionCosts' + k] | money }}</td>
        <td class="num">{{ hc.calc['revenue' + k] | money }}</td>
      </tr>
      {% endif %}
      {% endfor %}
    </tbody>
  </table>
  {% endif %}

  {# Leistungsphasen #}
  {% if hc.phases and hc.phases.length %}
  <div class="section-title-h">Leistungsphasen</div>
  <table class="data-table">
    <thead>
      <tr>
        <th style="width:38%">Leistungsphase</th>
        <th>Kx</th>
        <th class="num">Basis €</th>
        <th class="num">Basis %</th>
        <th class="num">Basis-Honorar €</th>
        <th class="num">Honorar %</th>
        <th class="num">Honorar €</th>
      </tr>
    </thead>
    <tbody>
      {% for p in hc.phases %}
      <tr>
        <td>{{ p.phaseLabel }}</td>
        <td>{{ p.kx }}</td>
        <td class="num">{{ p.revenueBase | money }}</td>
        <td class="num">{{ p.feePercentBase }}</td>
        <td class="num">{{ p.basisHonorar | money }}</td>
        <td class="num">{{ p.feePercent }}</td>
        <td class="num">{{ p.phaseRevenue | money }}</td>
      </tr>
      {% endfor %}
    </tbody>
    <tfoot>
      <tr><td colspan="5">Grundhonorar</td><td></td><td class="num">{{ hc.grundhonorar | money }}</td></tr>
    </tfoot>
  </table>
  {% endif %}

  {# Besondere Leistungen #}
  {% if hc.blItems and hc.blItems.length %}
  <div class="section-title-h">Besondere Leistungen</div>
  <table class="data-table">
    <thead>
      <tr>
        <th style="width:12%">Kürzel</th>
        <th style="width:45%">Bezeichnung</th>
        <th>LPH-Bezug</th>
        <th class="num">Betrag €</th>
      </tr>
    </thead>
    <tbody>
      {% for b in hc.blItems %}
      <tr>
        <td>{{ b.nameShort or "—" }}</td>
        <td>{{ b.name }}</td>
        <td>{{ b.lphLabel or b.lphRef or "—" }}</td>
        <td class="num">{{ b.amount | money }}</td>
      </tr>
      {% endfor %}
    </tbody>
    <tfoot><tr><td colspan="3">Summe Besondere Leistungen</td><td class="num">{{ hc.blTotal | money }}</td></tr></tfoot>
  </table>
  {% endif %}

  {# Zuschläge / Nachlässe #}
  {% if hc.surcharges and hc.surcharges.length %}
  <div class="section-title-h">Zuschläge &amp; Nachlässe</div>
  <table class="data-table">
    <thead>
      <tr>
        <th style="width:45%">Bezeichnung</th>
        <th class="num">%</th>
        <th class="num">Basis €</th>
        <th class="num">Betrag €</th>
      </tr>
    </thead>
    <tbody>
      {% for s in hc.surcharges %}
      <tr>
        <td>
          {{ s.nameLong or s.nameShort or "—" }}
          {% if s.calcMode == 'cumulative' %}<span class="surcharge-mode-badge">Kumulativ</span>{% endif %}
          {% if s.lphDetail %}<div class="surcharge-detail">Basis: {{ s.lphDetail }}</div>{% endif %}
        </td>
        <td class="num">{{ s.percent }}</td>
        <td class="num">{{ s.baseAmount | money }}</td>
        <td class="num">{{ s.amount | money }}</td>
      </tr>
      {% set hasDetail = (s.lphItems and s.lphItems.length > 0) or (s.surchargeBls and s.surchargeBls.length > 0) %}
      {% if hasDetail %}
      <tr class="breakdown-row">
        <td colspan="4">
          <table class="breakdown-table">
            <thead><tr>
              <th>Komponente</th>
              <th style="text-align:right">Basis €</th>
              <th style="text-align:right">Zuschlag €</th>
            </tr></thead>
            <tbody>
              {% for item in s.lphItems %}
              <tr class="bd-lph"><td>{{ item.label }}</td><td class="bd-num">{{ item.baseAmount | money }}</td><td class="bd-num">{{ item.surchargeAmount | money }}</td></tr>
              {% endfor %}
              {% for item in s.surchargeBls %}
              <tr class="bd-bl"><td>{{ item.name }}</td><td class="bd-num">{{ item.baseAmount | money }}</td><td class="bd-num">{{ item.surchargeAmount | money }}</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </td>
      </tr>
      {% endif %}
      {% endfor %}
    </tbody>
    <tfoot>
      <tr>
        <td colspan="3">Summe Zuschläge / Nachlässe</td>
        <td class="num">{{ hc.zuschlaegeSum | money }}</td>
      </tr>
    </tfoot>
  </table>
  {% endif %}

  {# Zusammenfassung #}
  <div class="honorar-summary">
    <table>
      <tr><td class="sl">Grundhonorar (Summe Leistungsphasen)</td><td class="sv">{{ hc.grundhonorar | money }}</td></tr>
      {% if hc.blItems and hc.blItems.length %}<tr><td class="sl">Besondere Leistungen</td><td class="sv">{{ hc.blTotal | money }}</td></tr>{% endif %}
      {% if hc.surcharges and hc.surcharges.length %}<tr><td class="sl">Zuschläge / Nachlässe</td><td class="sv">{{ hc.zuschlaegeSum | money }}</td></tr>{% endif %}
      <tr class="gesamthonorar"><td class="sl">Gesamthonorar (netto)</td><td class="sv">{{ hc.gesamthonorar | money }}</td></tr>
    </table>
  </div>

</div>
{% endfor %}
{% endif %}

{# ═══════════════════════════════════════ PAGE 2 – BESTELLBLATT ══════════════════════════ #}
<div class="page page-break">

  {# Logo #}
  <div class="logo-area">
    {% if theme.header.showLogo and logoDataUri %}
      <img src="{{ logoDataUri }}" alt="Logo">
    {% endif %}
  </div>

  <div class="bestellblatt-title">Bestellblatt</div>
  <div class="bestellblatt-subtitle">Falls Ihnen das Angebot zusagt, senden Sie es uns unterschrieben zurück.</div>

  {# Reference info box #}
  <div class="info-box">
    <table>
      <tr>
        <td class="lbl">Angebots-Nr.</td>
        <td class="val">{{ offer.NAME_SHORT }}</td>
      </tr>
      <tr>
        <td class="lbl">Angebotsdatum</td>
        <td class="val">{{ (offer.OFFER_DATE or offer.CREATED_AT) | date_de }}</td>
      </tr>
      {% if offer.VALID_UNTIL %}
      <tr>
        <td class="lbl">Gültig bis</td>
        <td class="val">{{ offer.VALID_UNTIL | date_de }}</td>
      </tr>
      {% endif %}
      <tr>
        <td class="lbl">Auftragnehmer</td>
        <td class="val">{{ seller.name }}</td>
      </tr>
      <tr>
        <td class="lbl" style="padding-top:2mm;">Angebotssumme {% if vatPercent > 0 %}(brutto){% else %}(netto){% endif %}</td>
        <td class="val total" style="padding-top:2mm;">{{ (grossTotal if vatPercent > 0 else totals.total) | money }}</td>
      </tr>
    </table>
  </div>

  {# Acceptance statement #}
  <div class="acceptance-text">
    Hiermit erteilen wir den Auftrag gemäß Angebot Nr.&nbsp;<strong>{{ offer.NAME_SHORT }}</strong>
    vom&nbsp;{{ (offer.OFFER_DATE or offer.CREATED_AT) | date_de }}
    über&nbsp;<strong>{{ (grossTotal if vatPercent > 0 else totals.total) | money }}</strong>
    {% if vatPercent > 0 %}(brutto, inkl. {{ vatPercent }}&thinsp;% MwSt.){% else %}(netto){% endif %}
    an&nbsp;{{ seller.name }}.
  </div>

  {# Order subject #}
  <div class="order-subject">{{ offer.NAME_LONG }}</div>

  {# Buyer info #}
  <div class="buyer-block">
    <strong>{{ buyer.name }}</strong>{% if buyer.name2 %}<br>{{ buyer.name2 }}{% endif %}
    {% if buyer.street %}<br>{{ buyer.street }}{% endif %}
    <br>{{ buyer.postCode }} {{ buyer.city }}
    {% if contact %}<br>{{ contact.FIRST_NAME }} {{ contact.LAST_NAME }}{% if contact.EMAIL %} &middot; {{ contact.EMAIL }}{% endif %}{% endif %}
  </div>

  {# Signature fields #}
  <div class="signature-section">
    <div class="signature-field">
      <div class="signature-line">Ort, Datum</div>
    </div>
    <div class="signature-field" style="flex: 2;">
      <div class="signature-line">Unterschrift, Firmenstempel (Auftraggeber)</div>
    </div>
  </div>

</div>

</body>
</html>
