# ── Owner-Konsole — Umgebungsvariablen ───────────────────────────────────────
# Eigener, von der Tenant-App UNABHÄNGIGER Satz Geheimnisse.

# Eigenes Secret (NICHT das JWT_SECRET der Tenant-App wiederverwenden!)
CONSOLE_JWT_SECRET=change-me-to-a-long-random-string

# Dieselbe Supabase-Datenbank wie die Hauptanwendung (Control-Plane verwaltet
# die globalen Lizenz-Tabellen -> Service-Key ist hier angemessen).
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>

# Port + erlaubte Origin(s) der Konsolen-UI (kommagetrennt).
CONSOLE_PORT=4000
CONSOLE_ORIGINS=http://localhost:4173

# NODE_ENV=production aktiviert HSTS-strikt + deaktiviert localhost-CORS.
NODE_ENV=development

# ── Jira-Übergabe (Vorschläge → Roadmap, optional) ───────────────────────────
# Ohne diese Variablen ist der Button „Als Jira-Ticket anlegen" inaktiv (klare
# Fehlermeldung). REST API v2, Basic-Auth mit E-Mail + API-Token.
JIRA_BASE_URL=https://<dein-raum>.atlassian.net
JIRA_EMAIL=<atlassian-konto-email>
JIRA_API_TOKEN=<api-token>
JIRA_PROJECT_KEY=<z.B. ROAD>
JIRA_ISSUE_TYPE=Task

# ── E-Mail-Benachrichtigung an Anwender (Resend, optional) ───────────────────
# Wird nur gesendet, wenn beide gesetzt sind; sonst still übersprungen (no-op).
# Dieselben Werte wie in der Tenant-App verwenden.
RESEND_API_KEY=<resend-api-key>
EMAIL_FROM=plan&simple <noreply@deine-domain.de>
